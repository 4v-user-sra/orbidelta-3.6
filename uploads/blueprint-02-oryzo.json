{
  "meta": {
    "source": "https://oryzo.ai/",
    "site_type": "AI/SaaS Product Landing Page",
    "overall_style": "Dark gradient-rich futuristic with glass morphism, orb glows, and smooth kinetic scroll. AI-native aesthetic.",
    "signature_patterns": ["Floating gradient orbs", "Glass card UI", "Horizontal scroll showcases", "Gradient mesh backgrounds", "Animated stat counters"]
  },

  "design_system": {
    "typography": {
      "primary_font": {
        "family": "General Sans / Plus Jakarta Sans (modern geometric sans)",
        "weights": [400, 500, 600, 700],
        "usage": "Body, UI elements, nav, descriptions"
      },
      "display_font": {
        "family": "Cabinet Grotesk / Clash Display (wide geometric display)",
        "weights": [400, 500, 600, 700],
        "usage": "Headlines, hero text, feature titles"
      },
      "scale": {
        "hero_headline": { "size": "clamp(3rem, 7vw, 6rem)", "line_height": "1.05", "letter_spacing": "-0.03em", "weight": 600 },
        "section_title": { "size": "clamp(2rem, 4vw, 3.5rem)", "line_height": "1.1", "letter_spacing": "-0.02em", "weight": 600 },
        "feature_title": { "size": "clamp(1.25rem, 1.8vw, 1.5rem)", "line_height": "1.3", "weight": 600 },
        "body": { "size": "clamp(0.9rem, 1vw, 1.0625rem)", "line_height": "1.7", "weight": 400 },
        "caption": { "size": "0.75rem", "letter_spacing": "0.08em", "text_transform": "uppercase", "weight": 600 },
        "hero_sub": { "size": "clamp(1rem, 1.3vw, 1.25rem)", "line_height": "1.6", "weight": 400, "color": "rgba(255,255,255,0.6)" }
      },
      "strategy": "Bolder weights than Refokus — 600 for headlines gives a more 'tech product' feel vs Refokus's 300-400 editorial feel."
    },

    "color_palette": {
      "background": {
        "primary": "#050510",
        "secondary": "#0A0A1A",
        "surface": "#0F0F24",
        "card": "rgba(15,15,36,0.6)"
      },
      "text": {
        "primary": "#FFFFFF",
        "secondary": "rgba(255,255,255,0.65)",
        "muted": "rgba(255,255,255,0.35)",
        "gradient_text": "linear-gradient(135deg, #FFFFFF 30%, rgba(255,255,255,0.5) 100%)"
      },
      "accent": {
        "primary": "#7C5CFC",
        "primary_light": "#A78BFA",
        "secondary": "#00D4FF",
        "tertiary": "#FF6B9D",
        "gradient_primary": "linear-gradient(135deg, #7C5CFC 0%, #00D4FF 100%)",
        "gradient_warm": "linear-gradient(135deg, #FF6B9D 0%, #FFA726 100%)",
        "gradient_cool": "linear-gradient(135deg, #00D4FF 0%, #7C5CFC 100%)"
      },
      "orb_colors": {
        "purple_orb": "radial-gradient(circle, rgba(124,92,252,0.4) 0%, rgba(124,92,252,0) 70%)",
        "cyan_orb": "radial-gradient(circle, rgba(0,212,255,0.3) 0%, rgba(0,212,255,0) 70%)",
        "pink_orb": "radial-gradient(circle, rgba(255,107,157,0.25) 0%, rgba(255,107,157,0) 70%)"
      },
      "strategy": "Deep navy-black base (#050510) instead of pure black — gives a cooler, more 'digital' feel. Multi-color gradient system vs Refokus's single accent. Purple-cyan axis is the signature."
    },

    "spacing": {
      "base_unit": "8px",
      "scale": {
        "xs": "4px", "sm": "8px", "md": "16px", "lg": "24px", "xl": "32px",
        "2xl": "48px", "3xl": "64px", "4xl": "96px", "5xl": "120px",
        "section_gap": "clamp(80px, 10vh, 140px)"
      },
      "container": { "max_width": "1200px", "padding_x": "clamp(16px, 4vw, 64px)" }
    },

    "grid": {
      "type": "CSS Grid",
      "columns": 12,
      "gutter": "20px",
      "common_layouts": {
        "hero": "full-width centered, max-width 800px for text",
        "features": "3-col equal grid with glass cards",
        "showcase": "horizontal scroll with snap points",
        "pricing": "3-col centered with featured middle card",
        "bento": "bento-grid with varying span sizes (2x2, 1x1, 2x1)"
      }
    }
  },

  "ui_components": {
    "buttons": {
      "primary": {
        "background": "linear-gradient(135deg, #7C5CFC 0%, #00D4FF 100%)",
        "color": "#FFFFFF",
        "padding": "14px 28px",
        "border_radius": "12px",
        "font_size": "0.9375rem",
        "font_weight": 600,
        "border": "none",
        "transition": "all 0.4s cubic-bezier(0.16, 1, 0.3, 1)",
        "hover": {
          "transform": "translateY(-2px)",
          "box_shadow": "0 8px 32px rgba(124,92,252,0.4), 0 0 60px rgba(124,92,252,0.15)",
          "filter": "brightness(1.1)"
        },
        "active": { "transform": "translateY(0)", "filter": "brightness(0.95)" }
      },
      "secondary": {
        "background": "rgba(255,255,255,0.06)",
        "color": "#FFFFFF",
        "border": "1px solid rgba(255,255,255,0.1)",
        "padding": "14px 28px",
        "border_radius": "12px",
        "backdrop_filter": "blur(10px)",
        "hover": {
          "background": "rgba(255,255,255,0.1)",
          "border_color": "rgba(255,255,255,0.2)",
          "box_shadow": "0 4px 16px rgba(0,0,0,0.3)"
        }
      },
      "pill_tag": {
        "background": "rgba(124,92,252,0.15)",
        "color": "#A78BFA",
        "padding": "6px 16px",
        "border_radius": "100px",
        "font_size": "0.75rem",
        "font_weight": 600,
        "letter_spacing": "0.04em",
        "border": "1px solid rgba(124,92,252,0.2)"
      }
    },

    "cards": {
      "glass_feature_card": {
        "background": "rgba(255,255,255,0.03)",
        "border": "1px solid rgba(255,255,255,0.06)",
        "border_radius": "20px",
        "padding": "32px",
        "backdrop_filter": "blur(20px)",
        "hover": {
          "background": "rgba(255,255,255,0.06)",
          "border_color": "rgba(124,92,252,0.3)",
          "transform": "translateY(-4px)",
          "box_shadow": "0 16px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06)",
          "transition": "all 0.5s cubic-bezier(0.16, 1, 0.3, 1)"
        },
        "icon_area": {
          "width": "48px",
          "height": "48px",
          "border_radius": "12px",
          "background": "linear-gradient(135deg, rgba(124,92,252,0.2) 0%, rgba(0,212,255,0.1) 100%)",
          "display": "flex",
          "align_items": "center",
          "justify_content": "center"
        }
      },
      "bento_card": {
        "background": "rgba(15,15,36,0.8)",
        "border": "1px solid rgba(255,255,255,0.05)",
        "border_radius": "24px",
        "padding": "40px",
        "backdrop_filter": "blur(12px)",
        "overflow": "hidden",
        "inner_glow": "inset 0 1px 0 rgba(255,255,255,0.05)"
      },
      "pricing_card": {
        "background": "rgba(255,255,255,0.03)",
        "border": "1px solid rgba(255,255,255,0.08)",
        "border_radius": "24px",
        "padding": "40px 32px",
        "featured_variant": {
          "border_color": "rgba(124,92,252,0.5)",
          "background": "rgba(124,92,252,0.08)",
          "box_shadow": "0 0 80px rgba(124,92,252,0.15)"
        }
      }
    },

    "navbar": {
      "position": "fixed",
      "z_index": 1000,
      "padding": "16px 24px",
      "background": "rgba(5,5,16,0.7)",
      "backdrop_filter": "blur(24px) saturate(1.3)",
      "border": "1px solid rgba(255,255,255,0.06)",
      "border_radius": "16px",
      "margin": "12px auto",
      "max_width": "fit-content",
      "style": "floating island — centered with rounded corners, not full-width",
      "links": {
        "color": "rgba(255,255,255,0.6)",
        "hover": "rgba(255,255,255,1)",
        "active_indicator": "2px bottom border gradient",
        "gap": "28px",
        "font_size": "0.875rem"
      }
    },

    "forms": {
      "input": {
        "background": "rgba(255,255,255,0.04)",
        "border": "1px solid rgba(255,255,255,0.08)",
        "border_radius": "12px",
        "padding": "14px 16px",
        "color": "#FFFFFF",
        "focus": {
          "border_color": "rgba(124,92,252,0.5)",
          "box_shadow": "0 0 20px rgba(124,92,252,0.15)",
          "background": "rgba(255,255,255,0.06)"
        }
      },
      "email_capture": {
        "layout": "inline — input + button side-by-side",
        "wrapper_background": "rgba(255,255,255,0.04)",
        "wrapper_border": "1px solid rgba(255,255,255,0.08)",
        "wrapper_border_radius": "16px",
        "wrapper_padding": "6px"
      }
    }
  },

  "visual_effects": {
    "glassmorphism": {
      "cards": {
        "background": "rgba(255,255,255,0.03)",
        "backdrop_filter": "blur(20px)",
        "border": "1px solid rgba(255,255,255,0.06)",
        "inner_highlight": "inset 0 1px 0 rgba(255,255,255,0.05)"
      },
      "navbar": {
        "background": "rgba(5,5,16,0.7)",
        "backdrop_filter": "blur(24px) saturate(1.3)"
      },
      "modal": {
        "background": "rgba(15,15,36,0.85)",
        "backdrop_filter": "blur(40px)"
      }
    },
    "shadows": {
      "card": "0 8px 32px rgba(0,0,0,0.4)",
      "card_hover": "0 16px 40px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.06)",
      "button_glow": "0 8px 32px rgba(124,92,252,0.4), 0 0 60px rgba(124,92,252,0.15)",
      "orb_shadow": "0 0 200px rgba(124,92,252,0.2)"
    },
    "glows": {
      "purple_ambient": "radial-gradient(600px at var(--x) var(--y), rgba(124,92,252,0.08), transparent 60%)",
      "hero_orb_1": { "size": "500px", "color": "rgba(124,92,252,0.25)", "position": "top-right", "blur": "150px" },
      "hero_orb_2": { "size": "400px", "color": "rgba(0,212,255,0.15)", "position": "bottom-left", "blur": "120px" },
      "section_accent": { "size": "300px", "color": "rgba(255,107,157,0.1)", "blur": "100px" }
    },
    "gradients": {
      "hero_mesh": "background: radial-gradient(at 20% 30%, rgba(124,92,252,0.15) 0%, transparent 50%), radial-gradient(at 80% 70%, rgba(0,212,255,0.1) 0%, transparent 50%)",
      "gradient_text": {
        "background": "linear-gradient(135deg, #FFFFFF 30%, rgba(124,92,252,0.8) 100%)",
        "webkit_background_clip": "text",
        "webkit_text_fill_color": "transparent"
      },
      "border_gradient": {
        "technique": "pseudo-element with gradient behind card + slightly larger, creating gradient border effect",
        "implementation": "position:relative → ::before with gradient bg → card bg on top via z-index"
      },
      "noise": { "opacity": "0.02-0.04", "blend_mode": "soft-light" }
    }
  },

  "motion_system": {
    "scroll_animations": {
      "fade_in_up": {
        "initial": { "opacity": 0, "translateY": "40px" },
        "final": { "opacity": 1, "translateY": "0" },
        "duration": "0.7s",
        "easing": "cubic-bezier(0.16, 1, 0.3, 1)",
        "trigger_offset": "15%"
      },
      "scale_in": {
        "initial": { "opacity": 0, "scale": "0.95" },
        "final": { "opacity": 1, "scale": "1" },
        "duration": "0.8s",
        "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
      },
      "stagger_cards": {
        "description": "Feature cards appear with stagger",
        "stagger_delay": "0.08s",
        "per_card": { "opacity": "0→1", "translateY": "30px→0", "scale": "0.97→1" },
        "duration": "0.6s"
      },
      "horizontal_showcase": {
        "description": "Work/portfolio section scrolls horizontally within vertical scroll",
        "technique": "CSS scroll-snap-type: x mandatory on container, translateX driven by scroll progress",
        "card_spacing": "24px",
        "snap_align": "center"
      },
      "orb_float": {
        "description": "Background gradient orbs float slowly",
        "animation": "keyframe translateX(0,30px) translateY(0,-20px)",
        "duration": "8-12s",
        "timing": "ease-in-out",
        "iteration": "infinite alternate"
      },
      "counter_roll": {
        "description": "Stat numbers count up on scroll",
        "duration": "2s",
        "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
      }
    },

    "hover_effects": {
      "card_lift": { "translateY": "-4px", "border_glow": true, "duration": "0.5s" },
      "button_lift": { "translateY": "-2px", "shadow_expand": true, "duration": "0.4s" },
      "gradient_shift": { "description": "Gradient backgrounds subtly shift on hover", "technique": "background-position animation" },
      "cursor_spotlight": {
        "description": "Mouse-following radial gradient highlight on cards",
        "implementation": "onMouseMove → update CSS --x --y vars → radial-gradient at var(--x) var(--y)",
        "color": "rgba(124,92,252,0.08)",
        "size": "400px"
      }
    },

    "page_transitions": { "type": "Fade + slight scale", "duration": "0.5s" },

    "timing_curves": {
      "default": "cubic-bezier(0.16, 1, 0.3, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "smooth": "cubic-bezier(0.25, 0.1, 0.25, 1)",
      "dramatic": "cubic-bezier(0.77, 0, 0.175, 1)"
    }
  },

  "scroll_behavior": {
    "parallax": {
      "orbs": { "speed": "0.15-0.3x", "property": "translateY + translateX" },
      "hero_content": { "speed": "0.5x fade out", "property": "opacity + translateY" }
    },
    "sticky_elements": {
      "section_titles": "sticky top for comparison/feature sections"
    },
    "transform_on_scroll": {
      "hero_scale_down": { "property": "scale", "from": "1", "to": "0.95", "range": "0-300px" },
      "card_reveal_stagger": "each card triggers at different scroll position"
    },
    "horizontal_scroll": {
      "technique": "Pin parent → translateX on child proportional to scroll",
      "snap": "scroll-snap-type: x mandatory",
      "implementation": "GSAP pin + horizontal translate OR CSS scroll-snap"
    }
  },

  "media_handling": {
    "images": { "format": "WebP/AVIF", "quality": "80", "treatment": "dark-themed product screenshots with purple/cyan overlay tint", "border_radius": "16-24px" },
    "videos": { "usage": "Product demo loops in hero or feature sections", "format": "MP4/WebM", "autoplay": true, "muted": true },
    "lazy_loading": { "strategy": "IntersectionObserver + skeleton/shimmer placeholders", "blur_placeholder": "10px blur version as LQIP" },
    "3d_elements": { "usage": "Possible Three.js/Spline 3D hero element", "fallback": "Static gradient mesh image for low-end devices" }
  },

  "performance": {
    "optimization_strategies": [
      "GPU-only animations (transform, opacity, filter)",
      "Reduce orb complexity on mobile (fewer, smaller, less blur)",
      "Lazy-load below-fold sections entirely",
      "Debounce cursor-follow effects",
      "prefers-reduced-motion: disable parallax and orb animations",
      "Use CSS containment on card grids"
    ]
  },

  "tech_stack_recommendation": {
    "frontend": "Next.js 14 or Nuxt 3",
    "animation_libs": ["Framer Motion (primary)", "GSAP ScrollTrigger (horizontal scroll)", "Lenis (smooth scroll)"],
    "styling": "Tailwind CSS + CSS variables",
    "3d": "Spline or Three.js for hero 3D element (optional)"
  },

  "replication_guidelines": {
    "dos": [
      "Use deep navy-black (#050510) not pure black",
      "Create gradient orbs with large border-radius divs + blur filter",
      "Apply glassmorphism with backdrop-filter blur(20px) + rgba backgrounds",
      "Use gradient text for hero headlines",
      "Implement cursor-following spotlight on cards",
      "Use bento grid for feature showcases",
      "Add floating animation to background orbs",
      "Keep 3-color gradient system (purple/cyan/pink)"
    ],
    "donts": [
      "Don't overuse gradients — max 2-3 gradient elements visible at once",
      "Don't make orb glows too bright (max 0.25 opacity)",
      "Don't apply blur to more than 5 elements simultaneously (perf)",
      "Don't skip the noise texture overlay",
      "Don't use sharp corners — everything 12px+ radius"
    ],
    "priority_elements": [
      "1. Gradient orb background atmosphere",
      "2. Glass feature cards with cursor spotlight",
      "3. Floating island navbar",
      "4. Gradient text on headlines",
      "5. Horizontal scroll showcase section",
      "6. Animated stat counters"
    ]
  }
}
